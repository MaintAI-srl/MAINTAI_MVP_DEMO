# Copia questo file in .env e compila i valori reali
# NON committare mai il file .env nel repository

# Database (PostgreSQL in cloud, SQLite in locale)
#
# Connessione DIRETTA (username = "postgres"):
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
#
# Pooler Supabase / Supavisor (consigliato in produzione, es. Render):
# ATTENZIONE: con il pooler lo username DEVE essere "postgres.<project-ref>",
# altrimenti il pooler rifiuta l'auth e apre il circuit breaker (ECIRCUITBREAKER).
#   - Session mode (porta 5432):     postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
#   - Transaction mode (porta 6543): postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
#
# Per sviluppo locale con SQLite:
# DATABASE_URL=sqlite:///./maintai.db

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# JWT Auth — OBBLIGATORIA: il backend NON si avvia se manca.
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambia-con-stringa-casuale-almeno-32-caratteri

# Cifratura password IMAP (Fernet) — OBBLIGATORIA: il backend NON si avvia se manca o è malformata.
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Sessione / cookie
# Durata access token in minuti (default 1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# "true" OBBLIGATORIO in produzione (cookie solo via HTTPS). In locale lascia vuoto.
COOKIE_SECURE=
# lax | strict | none
COOKIE_SAMESITE=lax

# Supabase Storage (lascia vuoto per usare uploads/ locale)
SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_BUCKET=maintai-uploads

# CORS (comma-separated, aggiorna con URL Vercel dopo deploy)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://TUO-PROGETTO.vercel.app
