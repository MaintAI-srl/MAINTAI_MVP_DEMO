{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MaintAI Desktop",
  "version": "3.3.2",
  "identifier": "com.maintai.desktop",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MaintAI Desktop",
        "url": "index.html",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://maintai-v3.onrender.com http://localhost:8000 http://127.0.0.1:8000; media-src 'self' blob:; object-src 'none'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3NENDRTE5RjZFQUQ0ClJXVFU2dllaemt4SEFNaEVTcENJclg3N0lvRExldGhuV08ybFRSV2dyZExLcmxxcGY3eEkyUFNFCg==",
      "endpoints": [
        "https://maintai-v3.onrender.com/desktop/update"
      ],
      "dialog": true,
      "windows": {
        "installerArgs": ["/SP-", "/SILENT", "/SUPPRESSMSGBOXES"]
      }
    }
  }
}
